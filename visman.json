    {
      "id": "food",
      "context": "canvas",
      "type": "circle",
      "position": {
        "x": 520,
        "y": 180
      },
      "size": {
        "radius": 7
      },
      "style": {
        "fillStyle": "#f59e0b",
        "strokeStyle": "#b45309",
        "lineWidth": 2
      },
      "physics": {
        "bodyType": "static"
      },
      "collision": {
        "collisionGroups": [
          "food"
        ],
        "collidesWith": [
          "snake-head"
        ],
        "trigger": true,
        "triggerAction": "eaten"
      },
      "actions": {
        "eaten": {
          "stateMutations": [
            {
              "path": "vm.score",
              "operation": "increment",
              "value": 1
            },
            {
              "path": "vm.length",
              "operation": "increment",
              "value": 1
            }
          ],
          "sequence": [
            "respawn_food"
          ]
        },
        "respawn_food": {
          "randomPick": [
            "p1",
            "p2",
            "p3",
            "p4",
            "p5",
            "p6",
            "p7",
            "p8",
            "p9",
            "p10"
          ]
        },
        "p1": {
          "transform": {
            "position": {
              "x": 80,
              "y": 80
            }
          }
        },
        "p2": {
          "transform": {
            "position": {
              "x": 140,
              "y": 220
            }
          }
        },
        "p3": {
          "transform": {
            "position": {
              "x": 220,
              "y": 100
            }
          }
        },
        "p4": {
          "transform": {
            "position": {
              "x": 280,
              "y": 280
            }
          }
        },
        "p5": {
          "transform": {
            "position": {
              "x": 360,
              "y": 140
            }
          }
        },
        "p6": {
          "transform": {
            "position": {
              "x": 420,
              "y": 260
            }
          }
        },
        "p7": {
          "transform": {
            "position": {
              "x": 500,
              "y": 80
            }
          }
        },
        "p8": {
          "transform": {
            "position": {
              "x": 560,
              "y": 220
            }
          }
        },
        "p9": {
          "transform": {
            "position": {
              "x": 200,
              "y": 320
            }
          }
        },
        "p10": {
          "transform": {
            "position": {
              "x": 440,
              "y": 320
            }
          }
        }
      }
    }
