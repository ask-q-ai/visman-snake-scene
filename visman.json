  "domLayer": [
    {
      "id": "snake-title",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 14,
        "y": 10
      },
      "properties": {
        "text": "SNAKE"
      },
      "style": {
        "color": "#86efac",
        "fontSize": 14,
        "fontFamily": "monospace",
        "fontWeight": "bold"
      }
    },
    {
      "id": "snake-score",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 14,
        "y": 30
      },
      "properties": {
        "text": "SCORE {{ @vm.score }}  LENGTH {{ @vm.length }}"
      },
      "style": {
        "color": "#e2e8f0",
        "fontSize": 13,
        "fontFamily": "monospace",
        "fontWeight": "bold"
      }
    },
    {
      "id": "snake-help",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 380,
        "y": 10
      },
      "properties": {
        "text": "Arrows to move"
      },
      "style": {
        "color": "#cbd5e1",
        "fontSize": 12,
        "fontFamily": "monospace"
      }
    },
    {
      "id": "game-over",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 210,
        "y": 130
      },
      "showWhen": {
        "@vm.gameOver": true
      },
      "properties": {
        "text": "GAME OVER"
      },
      "style": {
        "color": "#ef4444",
        "fontSize": 46,
        "fontWeight": "bold",
        "fontFamily": "monospace"
      }
    },
    {
      "id": "restart-btn",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 246,
        "y": 200
      },
      "size": {
        "width": 140,
        "height": 42
      },
      "showWhen": {
        "@vm.gameOver": true
      },
      "properties": {
        "text": "RESTART"
      },
      "style": {
        "fillStyle": "#16a34a",
        "color": "#ffffff",
        "fontSize": 20,
        "fontWeight": "bold",
        "fontFamily": "monospace"
      },
      "callbacks": {
        "onClick": "restart_game"
      },
      "actions": {
        "restart_game": {
          "restart": true
        }
      }
    }
  ]
}
