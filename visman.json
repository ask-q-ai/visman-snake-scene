    {
      "id": "tick-controller",
      "context": "canvas",
      "type": "circle",
      "visible": false,
      "position": {
        "x": -1000,
        "y": -1000
      },
      "callbacks": {
        "onBeat": "tick_tail"
      },
      "actions": {
        "tick_tail": {
          "stateMutations": [
            {
              "path": "vm.tail10x",
              "operation": "set",
              "value": "{{ @vm.tail9x }}"
            },
            {
              "path": "vm.tail10y",
              "operation": "set",
              "value": "{{ @vm.tail9y }}"
            },
            {
              "path": "vm.tail9x",
              "operation": "set",
              "value": "{{ @vm.tail8x }}"
            },
            {
              "path": "vm.tail9y",
              "operation": "set",
              "value": "{{ @vm.tail8y }}"
            },
            {
              "path": "vm.tail8x",
              "operation": "set",
              "value": "{{ @vm.tail7x }}"
            },
            {
              "path": "vm.tail8y",
              "operation": "set",
              "value": "{{ @vm.tail7y }}"
            },
            {
              "path": "vm.tail7x",
              "operation": "set",
              "value": "{{ @vm.tail6x }}"
            },
            {
              "path": "vm.tail7y",
              "operation": "set",
              "value": "{{ @vm.tail6y }}"
            },
            {
              "path": "vm.tail6x",
              "operation": "set",
              "value": "{{ @vm.tail5x }}"
            },
            {
              "path": "vm.tail6y",
              "operation": "set",
              "value": "{{ @vm.tail5y }}"
            },
            {
              "path": "vm.tail5x",
              "operation": "set",
              "value": "{{ @vm.tail4x }}"
            },
            {
              "path": "vm.tail5y",
              "operation": "set",
              "value": "{{ @vm.tail4y }}"
            },
            {
              "path": "vm.tail4x",
              "operation": "set",
              "value": "{{ @vm.tail3x }}"
            },
            {
              "path": "vm.tail4y",
              "operation": "set",
              "value": "{{ @vm.tail3y }}"
            },
            {
              "path": "vm.tail3x",
              "operation": "set",
              "value": "{{ @vm.tail2x }}"
            },
            {
              "path": "vm.tail3y",
              "operation": "set",
              "value": "{{ @vm.tail2y }}"
            },
            {
              "path": "vm.tail2x",
              "operation": "set",
              "value": "{{ @vm.tail1x }}"
            },
            {
              "path": "vm.tail2y",
              "operation": "set",
              "value": "{{ @vm.tail1y }}"
            },
            {
              "path": "vm.tail1x",
              "operation": "set",
              "value": "{{ @vm.objects.snake-head.position.x }}"
            },
            {
              "path": "vm.tail1y",
              "operation": "set",
              "value": "{{ @vm.objects.snake-head.position.y }}"
            }
          ]
        }
      }
    },
    {
      "id": "snake-head",
      "context": "canvas",
      "type": "rectangle",
      "position": {
        "x": 300,
        "y": 180
      },
      "size": {
        "width": 18,
        "height": 18
      },
      "style": {
        "fillStyle": "#22c55e",
        "strokeStyle": "#14532d",
        "lineWidth": 2
      },
      "physics": {
        "kinematic": true,
        "bodyType": "dynamic",
        "vx": 120,
        "vy": 0,
        "bounce": 0,
        "friction": 0,
        "fixedRotation": true
      },
      "collision": {
        "collisionGroups": [
          "snake-head"
        ],
        "collidesWith": [
          "wall",
          "snake-body"
        ],
        "onCollision": "die"
      },
      "actions": {
        "move_left": {
          "physics": {
            "vx": -120,
            "vy": 0
          }
        },
        "move_right": {
          "physics": {
            "vx": 120,
            "vy": 0
          }
        },
        "move_up": {
          "physics": {
            "vx": 0,
            "vy": -120
          }
        },
        "move_down": {
          "physics": {
            "vx": 0,
            "vy": 120
          }
        },
        "die": {
          "stateMutations": [
            {
              "path": "vm.gameOver",
              "operation": "set",
              "value": true
            }
          ],
          "sequence": [
            "stop_motion"
          ]
        },
        "stop_motion": {
          "physics": {
            "vx": 0,
            "vy": 0
          }
        }
      },
      "callbacks": {
        "onKeyPress": {
          "ArrowLeft": "move_left",
          "ArrowRight": "move_right",
          "ArrowUp": "move_up",
          "ArrowDown": "move_down"
        }
      }
    },
    {
      "id": "snake-body-1",
      "context": "canvas",
      "type": "rectangle",
      "position": {
        "x": "{{ @vm.length > 2 ? @vm.tail1x : -1000 }}",
        "y": "{{ @vm.length > 2 ? @vm.tail1y : -1000 }}"
      },
      "size": {
